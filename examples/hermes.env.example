# Optional Hermes Agent runtime example.
# This is not required by Discordia. Use only if Hermes is your chosen runtime.
# Copy relevant keys to the active Hermes profile .env file.
# Default profile: ~/.hermes/.env
# Named profile: ~/.hermes/profiles/PROFILE/.env

DISCORD_BOT_TOKEN=<DISCORD_BOT_TOKEN>
DISCORD_ALLOWED_USERS=<COMMA_SEPARATED_DISCORD_USER_IDS>
DISCORD_ALLOWED_ROLES=<COMMA_SEPARATED_DISCORD_ROLE_IDS>
DISCORD_HOME_CHANNEL=<DISCORD_CHANNEL_ID>
DISCORD_FREE_RESPONSE_CHANNELS=<COMMA_SEPARATED_DISCORD_CHANNEL_IDS>
DISCORD_REQUIRE_MENTION=true
DISCORD_AUTO_THREAD=true
